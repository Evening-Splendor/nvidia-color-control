{
  "name": "nvidia-color-control",
  "version": "1.0.2",
  "description": "NVIDIA GPU Color Channel Control - Modern Electron UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.nvidia.colorcontrol",
    "productName": "NVIDIA Color Control",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**",
      "node_modules/**",
      "!node_modules/koffi/doc/**",
      "!node_modules/koffi/src/**",
      "!node_modules/koffi/build/koffi/darwin*/**",
      "!node_modules/koffi/build/koffi/freebsd*/**",
      "!node_modules/koffi/build/koffi/linux*/**",
      "!node_modules/koffi/build/koffi/musl*/**",
      "!node_modules/koffi/build/koffi/openbsd*/**",
      "!node_modules/koffi/build/koffi/win32_ia32/**",
      "!node_modules/koffi/build/koffi/win32_arm64/**",
      "!node_modules/png-to-ico/node_modules/**"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "33.4.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "koffi": "^2.9.0",
    "png-to-ico": "^3.0.2"
  }
}
